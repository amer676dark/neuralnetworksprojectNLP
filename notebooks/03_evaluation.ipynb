{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Notebook 3: Evaluation & Results\n",
    "\n",
    "This notebook evaluates all models and produces:\n",
    "1. WER / CER scores per model\n",
    "2. Side-by-side transcript comparison\n",
    "3. Model comparison bar chart\n",
    "4. Per-sample error distribution\n",
    "5. Architecture summary table"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "sys.path.insert(0, '..')\n",
    "\n",
    "import json\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import yaml\n",
    "\n",
    "from utils.metrics import compute_wer, compute_cer, compute_batch_metrics, format_metrics_report\n",
    "from utils.visualization import plot_model_comparison, plot_confusion_matrix_wer\n",
    "\n",
    "with open('../configs/config.yaml') as f:\n",
    "    config = yaml.safe_load(f)\n",
    "\n",
    "print('Setup OK')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Load Test Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from data.dataset import load_common_voice_arabic\n",
    "\n",
    "test_ds = load_common_voice_arabic('test', max_samples=100)\n",
    "test_samples = list(test_ds)\n",
    "references = [s['sentence'] for s in test_samples]\n",
    "\n",
    "print(f'Test samples: {len(test_samples)}')\n",
    "print(f'Example: {references[0]}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Whisper Evaluation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from models.whisper_asr import WhisperASR\n",
    "from tqdm.notebook import tqdm\n",
    "\n",
    "whisper = WhisperASR(model_size='tiny', language='ar')  # use 'medium' for production\n",
    "\n",
    "whisper_hyps = []\n",
    "for s in tqdm(test_samples, desc='Whisper'):\n",
    "    audio = s['audio']['array'].astype(float)\n",
    "    whisper_hyps.append(whisper.transcribe_array(audio))\n",
    "\n",
    "whisper_metrics = compute_batch_metrics(references, whisper_hyps)\n",
    "print(format_metrics_report(whisper_metrics))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Wav2Vec 2.0 Evaluation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from models.wav2vec_asr import Wav2Vec2ASR\n",
    "\n",
    "wav2vec = Wav2Vec2ASR()\n",
    "\n",
    "wav2vec_hyps = []\n",
    "for s in tqdm(test_samples, desc='Wav2Vec2'):\n",
    "    audio = s['audio']['array'].astype(float)\n",
    "    wav2vec_hyps.append(wav2vec.transcribe_array(audio))\n",
    "\n",
    "wav2vec_metrics = compute_batch_metrics(references, wav2vec_hyps)\n",
    "print(format_metrics_report(wav2vec_metrics))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Model Comparison"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "model_names = ['Whisper-tiny', 'Wav2Vec2-XLSR']\n",
    "wer_scores  = [whisper_metrics['wer'], wav2vec_metrics['wer']]\n",
    "cer_scores  = [whisper_metrics['cer'], wav2vec_metrics['cer']]\n",
    "\n",
    "# If CNN+LSTM checkpoint exists, add it too\n",
    "import os\n",
    "ckpt = '../outputs/checkpoints/cnn_lstm/best_model.pt'\n",
    "if os.path.exists(ckpt):\n",
    "    import torch\n",
    "    from models.cnn_lstm_asr import build_model\n",
    "    from utils.audio_utils import extract_mel_spectrogram, normalize_audio, pad_or_trim\n",
    "\n",
    "    state = torch.load(ckpt, map_location='cpu')\n",
    "    vocab = state['vocab']\n",
    "    idx2char = {v: k for k, v in vocab.items()}\n",
    "    dev = torch.device('cpu')\n",
    "    cnn_model = build_model(len(vocab), config).to(dev)\n",
    "    cnn_model.load_state_dict(state['model_state'])\n",
    "    cnn_model.eval()\n",
    "\n",
    "    cnn_hyps = []\n",
    "    for s in tqdm(test_samples, desc='CNN+LSTM'):\n",
    "        audio = normalize_audio(s['audio']['array'].astype(np.float32))\n",
    "        audio = pad_or_trim(audio, config['audio']['max_audio_length'])\n",
    "        mel = extract_mel_spectrogram(audio, n_mels=config['audio']['n_mels'])\n",
    "        mel_t = torch.tensor(mel, dtype=torch.float32).unsqueeze(0).unsqueeze(0)\n",
    "        mel_t = (mel_t - mel_t.mean()) / (mel_t.std() + 1e-8)\n",
    "        with torch.no_grad():\n",
    "            lp = cnn_model(mel_t)\n",
    "        ids = cnn_model.greedy_decode(lp)[0]\n",
    "        cnn_hyps.append(''.join(idx2char.get(i, '') for i in ids if i not in {0,2,3}))\n",
    "\n",
    "    cnn_metrics = compute_batch_metrics(references, cnn_hyps)\n",
    "    model_names.append('CNN+LSTM')\n",
    "    wer_scores.append(cnn_metrics['wer'])\n",
    "    cer_scores.append(cnn_metrics['cer'])\n",
    "    print(format_metrics_report(cnn_metrics))\n",
    "\n",
    "plot_model_comparison(model_names, wer_scores, cer_scores,\n",
    "                      save_path='../outputs/results/model_comparison.png')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Side-by-Side Transcript Comparison"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "df = pd.DataFrame({\n",
    "    'Reference':   references[:10],\n",
    "    'Whisper':     whisper_hyps[:10],\n",
    "    'Wav2Vec2':    wav2vec_hyps[:10],\n",
    "    'Whisper WER': [compute_wer([r],[h]) for r,h in zip(references[:10], whisper_hyps[:10])],\n",
    "    'W2V WER':     [compute_wer([r],[h]) for r,h in zip(references[:10], wav2vec_hyps[:10])],\n",
    "})\n",
    "\n",
    "pd.set_option('display.max_colwidth', 60)\n",
    "df"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Architecture Summary Table"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "arch_data = {\n",
    "    'Model':         ['CNN+LSTM (custom)', 'Wav2Vec 2.0 XLSR', 'Whisper medium'],\n",
    "    'Architecture':  ['CNN + BiLSTM + CTC', 'CNN + Transformer + CTC', 'Encoder-Decoder Transformer'],\n",
    "    'Parameters':    ['~8M', '300M', '769M'],\n",
    "    'Training':      ['From scratch (CTC)', 'Fine-tuned (pretrained)', 'Zero-shot'],\n",
    "    'Arabic WER':    ['~40-60%', '~20-35%', '~15-25%'],\n",
    "    'Speed':         ['Fast', 'Medium', 'Slow (large model)'],\n",
    "    'GPU Required':  ['No (CPU ok)', 'Recommended', 'Recommended'],\n",
    "}\n",
    "pd.DataFrame(arch_data)"
   ]
  }
